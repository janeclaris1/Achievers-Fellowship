# Frontend Environment Variables
# Copy this file to .env and fill in your Supabase project details

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# The following are set in Supabase Dashboard → Edge Functions → Secrets
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
# PAYSTACK_SECRET_KEY=sk_test_... or sk_live_...
# APP_URL=https://your-production-domain.com
# PARTNERSHIP_CRON_SECRET=optional-random-string-for-cron-auth
# ANTHROPIC_API_KEY=sk-ant-...
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# RESEND_API_KEY=re_xxxx
# CHURCH_EMAIL=archeivers@gmail.com
